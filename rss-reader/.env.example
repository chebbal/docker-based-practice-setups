# Copy to .env and fill in. .env is git-ignored.

# Public domain whose DNS A record points at this VPS's PUBLIC IP.
DOMAIN=rss.example.com

# Email for Let's Encrypt certificate-expiry notices.
ACME_EMAIL=you@example.com

# HTTP Basic auth username.
BASIC_AUTH_USER=admin

# HTTP Basic auth password as a bcrypt hash.
# Generate it (with every $ escaped to $$ so Compose won't treat it as a var):
#   docker run --rm caddy caddy hash-password --plaintext 'your-password' | sed 's/\$/$$/g'
# Paste the escaped output below.
BASIC_AUTH_HASH=REPLACE_ME
